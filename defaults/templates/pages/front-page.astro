---
import type { WpPageTemplateProps as Props } from 'wp-types';

const { Layout, title = 'Home', content = '' } = Astro.props;
---
<Layout {...Astro.props}>
  <article>
    <p style="font: 12px/1.4 ui-monospace, SFMono-Regular, Menlo, monospace; color: #666; text-transform: uppercase; letter-spacing: .08em;">Front page</p>
    <h1>{title}</h1>
    <div set:html={content} />
  </article>
</Layout>
