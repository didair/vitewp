---
export const prerender = false;

import { getLiveEntry } from 'astro:content';
import { createTemplateContext, templateCandidates } from 'vite-wp/wordpress';
import type { WpResolvedRoute } from 'wp-types';

type TemplateModule = {
  default: unknown;
};

const slug = Astro.params.slug ?? '';
const routePath = `${Astro.url.pathname}${Astro.url.search}`;
const routeResult = await getLiveEntry('routes', { path: routePath });

if (routeResult.error && routeResult.error.name !== 'LiveEntryNotFoundError') {
  throw routeResult.error;
}

const route = routeResult.entry?.data as WpResolvedRoute | undefined;
let candidates: string[] = [];

if (!route) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not Found';
}

const projectTemplates = import.meta.glob<TemplateModule>('/src/templates/**/*.astro');
const defaultTemplates = import.meta.glob<TemplateModule>('../defaults/templates/**/*.astro');
const projectLayouts = import.meta.glob<TemplateModule>('/src/templates/layouts/**/*.astro');
const defaultLayouts = import.meta.glob<TemplateModule>('../defaults/templates/layouts/**/*.astro');
let Template: any = null;
let Layout: any = null;
let templatePath = '';
let templateSource: 'project' | 'vite-wp' | null = null;
const showDebug = import.meta.env.DEV;
let context = null;

const projectLayoutLoader = projectLayouts['/src/templates/layouts/Base.astro'];
const defaultLayoutLoader = defaultLayouts['../defaults/templates/layouts/Base.astro'];
const layoutLoader = projectLayoutLoader ?? defaultLayoutLoader;

if (layoutLoader) {
  Layout = (await layoutLoader()).default;
}

if (route) {
  context = createTemplateContext(route, {
    path: routePath,
    url: Astro.url.toString(),
  });
  candidates = templateCandidates(route);

  for (const candidate of candidates) {
    const projectPath = `/src/templates/${candidate}`;
    const defaultPath = `../defaults/templates/${candidate}`;
    const projectLoader = projectTemplates[projectPath];
    const defaultLoader = defaultTemplates[defaultPath];
    const loader = projectLoader ?? defaultLoader;

    if (loader) {
      Template = (await loader()).default;
      templatePath = candidate;
      templateSource = projectLoader ? 'project' : 'vite-wp';
      break;
    }
  }
} else {
  candidates = ['404.astro'];
  const projectLoader = projectTemplates['/src/templates/404.astro'];
  const defaultLoader = defaultTemplates['../defaults/templates/404.astro'];
  const loader = projectLoader ?? defaultLoader;

  if (loader) {
    Template = (await loader()).default;
    templatePath = '404.astro';
    templateSource = projectLoader ? 'project' : 'vite-wp';
  }
}

const toolbarRouteInfo = showDebug ? {
  path: routePath,
  matched: Boolean(route),
  kind: context?.route.kind ?? '404',
  liveCollection: routeResult.entry ? {
    collection: 'routes',
    entryId: routeResult.entry.id,
    cacheHint: routeResult.cacheHint ?? null,
  } : null,
  postType: context?.postType ?? null,
  slug: context?.slug ?? null,
  page: context?.page ?? null,
  totalPages: context?.totalPages ?? null,
  template: templatePath || null,
  templateSource,
  candidateTemplates: candidates,
} : null;
---
{Template && context ? (
  <Template {...context} Layout={Layout} toolbarRouteInfo={toolbarRouteInfo} />
) : Template ? (
  <Template slug={slug} Layout={Layout} toolbarRouteInfo={toolbarRouteInfo} />
) : Layout ? (
  <Layout title="Not found" toolbarRouteInfo={toolbarRouteInfo}>
    <article>
      <h1>Not found</h1>
      <p>No WordPress route matched <code>{Astro.url.pathname}</code>.</p>
    </article>
  </Layout>
) : (
  <article>
    <h1>Not found</h1>
    <p>No WordPress route matched <code>{Astro.url.pathname}</code>.</p>
  </article>
)}
